// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String
  password  String
  account   Accounts @relation(fields: [accountId], references: [id])
  accountId String   @unique
}

model Accounts {
  id                   String         @id @default(uuid())
  balance              Float
  User                 User[]
  debitedTransactions  Transactions[] @relation("DebitedTransactions")
  creditedTransactions Transactions[] @relation("CreditedTransactions")
}

model Transactions {
  id                String   @id @default(uuid())
  debitedAccount    Accounts @relation("DebitedTransactions", fields: [debitedAccountId], references: [id])
  debitedAccountId  String
  creditedAccount   Accounts @relation("CreditedTransactions", fields: [creditedAccountId], references: [id])
  creditedAccountId String
  value             Float
  createdAt         DateTime @default(now())
}
